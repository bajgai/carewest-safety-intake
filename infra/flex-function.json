{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "functionAppName": { "type": "string" },
    "planName": { "type": "string", "defaultValue": "carewest-intake-flex-plan" },
    "location": { "type": "string", "defaultValue": "canadacentral" },
    "hostStorageName": { "type": "string" },
    "dataStorageName": { "type": "string" },
    "deploymentContainerName": { "type": "string", "defaultValue": "function-releases" },
    "maximumInstanceCount": { "type": "int", "defaultValue": 2, "minValue": 1, "maxValue": 100 },
    "instanceMemoryMB": { "type": "int", "defaultValue": 512, "allowedValues": [512, 2048, 4096] },
    "managedIdentityResourceId": { "type": "string" },
    "managedIdentityClientId": { "type": "string" },
    "extensibleIntakeEnabled": { "type": "bool", "defaultValue": false },
    "dataverseOrgUrl": { "type": "string", "defaultValue": "" },
    "dataverseIntakeEntitySet": { "type": "string", "defaultValue": "" },
    "dataverseFieldMapJson": { "type": "secureString", "defaultValue": "" },
    "applicationInsightsConnectionString": { "type": "secureString", "defaultValue": "" }
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2024-04-01",
      "name": "[parameters('planName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp",
      "sku": { "tier": "FlexConsumption", "name": "FC1" },
      "properties": { "reserved": true }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2024-04-01",
      "name": "[parameters('functionAppName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp,linux",
      "dependsOn": ["[resourceId('Microsoft.Web/serverfarms', parameters('planName'))]"],
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[parameters('managedIdentityResourceId')]": {}
        }
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('planName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "minTlsVersion": "1.2",
          "ftpsState": "Disabled",
          "cors": {
            "allowedOrigins": [
              "https://proud-beach-0b03f2b10.7.azurestaticapps.net",
              "https://bajgai.github.io"
            ],
            "supportCredentials": false
          }
        },
        "functionAppConfig": {
          "deployment": {
            "storage": {
              "type": "blobContainer",
              "value": "[concat('https://', parameters('hostStorageName'), '.blob.core.windows.net/', parameters('deploymentContainerName'))]",
              "authentication": {
                "type": "UserAssignedIdentity",
                "userAssignedIdentityResourceId": "[parameters('managedIdentityResourceId')]"
              }
            }
          },
          "scaleAndConcurrency": {
            "maximumInstanceCount": "[parameters('maximumInstanceCount')]",
            "instanceMemoryMB": "[parameters('instanceMemoryMB')]"
          },
          "runtime": { "name": "node", "version": "22" }
        }
      }
    },
    {
      "type": "Microsoft.Web/sites/config",
      "apiVersion": "2024-04-01",
      "name": "[concat(parameters('functionAppName'), '/appsettings')]",
      "dependsOn": ["[resourceId('Microsoft.Web/sites', parameters('functionAppName'))]"],
      "properties": {
        "AzureWebJobsStorage__accountName": "[parameters('hostStorageName')]",
        "AzureWebJobsStorage__credential": "managedidentity",
        "AzureWebJobsStorage__clientId": "[parameters('managedIdentityClientId')]",
        "CarewestStorage__queueServiceUri": "[concat('https://', parameters('dataStorageName'), '.queue.core.windows.net')]",
        "CarewestStorage__credential": "managedidentity",
        "CarewestStorage__clientId": "[parameters('managedIdentityClientId')]",
        "AZURE_CLIENT_ID": "[parameters('managedIdentityClientId')]",
        "CAREWEST_STORAGE_ACCOUNT": "[parameters('dataStorageName')]",
        "CAREWEST_TABLE_NAME": "SafetyIntakeOutbox",
        "CAREWEST_QUEUE_NAME": "safety-intake-delivery",
        "CAREWEST_EXTENSIBLE_INTAKE_ENABLED": "[string(parameters('extensibleIntakeEnabled'))]",
        "CAREWEST_CONFIG_TABLE_NAME": "CarewestIntakeConfig",
        "CAREWEST_DATAVERSE_QUEUE_NAME": "carewest-dataverse-delivery",
        "DATAVERSE_ORG_URL": "[parameters('dataverseOrgUrl')]",
        "DATAVERSE_INTAKE_ENTITY_SET": "[parameters('dataverseIntakeEntitySet')]",
        "DATAVERSE_FIELD_MAP_JSON": "[parameters('dataverseFieldMapJson')]",
        "APPLICATIONINSIGHTS_CONNECTION_STRING": "[parameters('applicationInsightsConnectionString')]"
      }
    }
  ],
  "outputs": {
    "functionHost": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', parameters('functionAppName')), '2024-04-01').defaultHostName]"
    }
  }
}
