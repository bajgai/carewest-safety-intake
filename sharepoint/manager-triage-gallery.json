{
  "$schema": "https://developer.microsoft.com/json-schemas/sp/v2/tile-formatting.schema.json",
  "height": 286,
  "width": 420,
  "hideSelection": false,
  "formatter": {
    "elmType": "div",
    "customRowAction": {
      "action": "defaultClick"
    },
    "style": {
      "height": "100%",
      "box-sizing": "border-box",
      "padding": "18px",
      "border": "1px solid #E6E8EB",
      "border-left": "=if([$Urgency] == '5 - Emergency', '7px solid #D8002A', if([$Urgency] == '3 - High', '7px solid #D8002A', if([$Urgency] == '2 - Medium', '7px solid #FFC72C', '7px solid #2E7D32')))",
      "border-radius": "12px",
      "background-color": "#FFFFFF",
      "box-shadow": "0 2px 8px rgba(1,66,106,0.10)",
      "display": "flex",
      "flex-direction": "column",
      "gap": "11px",
      "cursor": "pointer",
      "overflow": "hidden"
    },
    "children": [
      {
        "elmType": "div",
        "style": {
          "display": "flex",
          "align-items": "flex-start",
          "justify-content": "space-between",
          "gap": "12px"
        },
        "children": [
          {
            "elmType": "div",
            "style": {
              "min-width": "0",
              "flex-grow": "1"
            },
            "children": [
              {
                "elmType": "div",
                "txtContent": "=if([$Hazard_x0020_Area] == '', [$Site], [$Site] + ' — ' + [$Hazard_x0020_Area])",
                "style": {
                  "font-size": "18px",
                  "font-weight": "700",
                  "line-height": "1.25",
                  "color": "#01426A",
                  "height": "45px",
                  "display": "-webkit-box",
                  "-webkit-line-clamp": "2",
                  "-webkit-box-orient": "vertical",
                  "overflow": "hidden",
                  "text-overflow": "ellipsis"
                }
              },
              {
                "elmType": "div",
                "txtContent": "=if([$Report_x0020_Type] == '', 'Safety report', [$Report_x0020_Type])",
                "style": {
                  "font-size": "12px",
                  "font-weight": "600",
                  "color": "#54565A",
                  "margin-top": "4px"
                }
              }
            ]
          },
          {
            "elmType": "div",
            "txtContent": "[$Status]",
            "style": {
              "flex-shrink": "0",
              "max-width": "130px",
              "padding": "5px 9px",
              "border-radius": "999px",
              "font-size": "11px",
              "font-weight": "700",
              "line-height": "1.2",
              "text-align": "center",
              "color": "=if([$Status] == 'Closed by Site Manager', '#1D5B20', '#01426A')",
              "background-color": "=if([$Status] == 'Closed by Site Manager', '#EAF6EC', '#F3F8FC')",
              "border": "=if([$Status] == 'Closed by Site Manager', '1px solid #BFE2C2', '1px solid #C9DCE8')"
            }
          }
        ]
      },
      {
        "elmType": "div",
        "style": {
          "display": "flex",
          "flex-wrap": "wrap",
          "gap": "7px",
          "min-height": "27px"
        },
        "children": [
          {
            "elmType": "span",
            "txtContent": "=if([$Urgency] == '', 'Urgency not set', [$Urgency])",
            "style": {
              "padding": "5px 9px",
              "border-radius": "7px",
              "font-size": "11px",
              "font-weight": "700",
              "color": "=if([$Urgency] == '5 - Emergency' || [$Urgency] == '3 - High', '#7A0A22', if([$Urgency] == '2 - Medium', '#6E4700', '#1D5B20'))",
              "background-color": "=if([$Urgency] == '5 - Emergency' || [$Urgency] == '3 - High', '#FCEEF1', if([$Urgency] == '2 - Medium', '#FFF6E6', '#EAF6EC'))"
            }
          },
          {
            "elmType": "span",
            "txtContent": "='Injury: ' + [$Injury_x002f_Illness_x0020_Flag]",
            "style": {
              "display": "=if([$Injury_x002f_Illness_x0020_Flag] == '' || [$Injury_x002f_Illness_x0020_Flag] == 'No', 'none', 'inline-block')",
              "padding": "5px 9px",
              "border-radius": "7px",
              "font-size": "11px",
              "font-weight": "700",
              "color": "#7A0A22",
              "background-color": "#FCEEF1"
            }
          },
          {
            "elmType": "span",
            "txtContent": "Area not safe",
            "style": {
              "display": "=if([$Area_x0020_Safe_x0020_Now] == 'No - site manager help needed', 'inline-block', 'none')",
              "padding": "5px 9px",
              "border-radius": "7px",
              "font-size": "11px",
              "font-weight": "700",
              "color": "#7A0A22",
              "background-color": "#FCEEF1"
            }
          }
        ]
      },
      {
        "elmType": "div",
        "txtContent": "=if([$Description] == '', 'No description provided.', [$Description])",
        "style": {
          "height": "42px",
          "display": "-webkit-box",
          "-webkit-line-clamp": "2",
          "-webkit-box-orient": "vertical",
          "font-size": "13px",
          "line-height": "1.55",
          "color": "#1C1C1E",
          "overflow": "hidden",
          "text-overflow": "ellipsis"
        }
      },
      {
        "elmType": "div",
        "style": {
          "margin-top": "auto",
          "padding-top": "10px",
          "border-top": "1px solid #EBEBEB",
          "display": "flex",
          "align-items": "flex-end",
          "justify-content": "space-between",
          "gap": "12px"
        },
        "children": [
          {
            "elmType": "div",
            "children": [
              {
                "elmType": "div",
                "txtContent": "=if([$Site_x0020_Manager_x0020_Action] == '', 'Review required', [$Site_x0020_Manager_x0020_Action])",
                "style": {
                  "font-size": "13px",
                  "font-weight": "700",
                  "color": "#01426A"
                }
              },
              {
                "elmType": "div",
                "txtContent": "=toLocaleDateString([$Submitted_x0020_Date_x002f_Time])",
                "style": {
                  "font-size": "11px",
                  "color": "#54565A",
                  "margin-top": "3px"
                }
              }
            ]
          },
          {
            "elmType": "div",
            "txtContent": "[$Title]",
            "style": {
              "font-size": "10px",
              "font-weight": "600",
              "color": "#54565A",
              "text-align": "right",
              "max-width": "150px",
              "white-space": "nowrap",
              "overflow": "hidden",
              "text-overflow": "ellipsis"
            }
          }
        ]
      }
    ]
  }
}
